{
  "name": "website-alexendrosme",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Sitio web personal de Alexendros — espacio libre de dinero para ideas, ensayos y crítica tecnológica. Next.js 16, Tailwind v4, TypeScript strict, export estático.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run generate-sitemap && npm run generate-search-index && next build",
    "generate-search-index": "tsx scripts/generate-search-index.ts",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "validate-jsonld": "tsx scripts/validate-jsonld.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test --grep @visual",
    "test:hash": "tsx scripts/hash-inline-blocks.ts",
    "deploy": "vercel deploy --prod --yes",
    "deploy:preview": "vercel deploy --yes",
    "verify:vercel": "tsx scripts/verify-vercel-config.ts",
    "verify:action-shas": "tsx scripts/validate-action-shas.ts",
    "deadcode:deps": "depcheck",
    "deadcode:exports": "ts-prune",
    "test:e2e": "playwright test --grep-invert @visual",
    "test:e2e:ui": "playwright test --ui",
    "audit:hydration": "tsx scripts/hydration-warning-audit.ts",
    "prepare": "husky",
    "release": "standard-version"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "radix-ui": "^1.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.27.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "depcheck": "^1.4.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "serve": "^14.2.6",
    "ts-prune": "^0.10.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.0",
  "license": "MIT",
  "author": "Alexendros <contacto@alexendros.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexendros/website-alexendrosme.git"
  },
  "homepage": "https://alexendros.me",
  "bugs": {
    "url": "https://github.com/Alexendros/website-alexendrosme/issues"
  },
  "keywords": [
    "personal-website",
    "nextjs",
    "tailwindcss",
    "typescript",
    "design-system",
    "static-site",
    "alexendros"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "overrides": {
    "postcss@<8.5.10": ">=8.5.10"
  }
}
