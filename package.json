{
  "name": "website-alexendrosme",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Sitio web personal de Alexendros — espacio libre de dinero para ideas, ensayos y crítica tecnológica. Next.js 16, Tailwind v4, TypeScript strict, export estático.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "deadcode:deps": "depcheck",
    "deadcode:exports": "ts-prune",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky || true",
    "release": "standard-version"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.26.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "serve": "^14.2.6",
    "ts-prune": "^0.10.3",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.0",
  "license": "MIT",
  "author": "Alexendros <contacto@alexendros.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexendros/website-alexendrosme.git"
  },
  "homepage": "https://alexendros.me",
  "bugs": {
    "url": "https://github.com/Alexendros/website-alexendrosme/issues"
  },
  "keywords": [
    "personal-website",
    "nextjs",
    "tailwindcss",
    "typescript",
    "design-system",
    "static-site",
    "alexendros"
  ],
  "overrides": {
    "postcss@<8.5.10": ">=8.5.10"
  }
}
